<script>
// EMBER PARTICLES — red-only
const cv=document.getElementById('bgcanvas'),cx=cv.getContext('2d');
let pts=[];
function rsz(){cv.width=window.innerWidth;cv.height=window.innerHeight;}
function init(){
  pts=[];
  const n=Math.floor(window.innerWidth/9);
  for(let i=0;i<n;i++){
    const isRed=Math.random()>.3;
    pts.push({
      x:Math.random()*cv.width,y:cv.height+Math.random()*cv.height,
      vx:(Math.random()-.5)*.35,vy:-(Math.random()*.55+.12),
      r:Math.random()*1.3+.2,a:Math.random()*.35+.04,
      c:isRed?[204,26,14]:[230,60,40]
    });
  }
}
function draw(){
  cx.clearRect(0,0,cv.width,cv.height);
  pts.forEach(p=>{
    cx.beginPath();cx.arc(p.x,p.y,p.r,0,Math.PI*2);
    cx.fillStyle=`rgba(${p.c[0]},${p.c[1]},${p.c[2]},${p.a})`;
    cx.fill();
    p.x+=p.vx;p.y+=p.vy;
    if(p.y<-10){p.y=cv.height+10;p.x=Math.random()*cv.width;}
  });
  requestAnimationFrame(draw);
}
rsz();init();draw();
window.addEventListener('resize',()=>{rsz();init();});

// CURSOR
const cur=document.getElementById('cursor'),ring=document.getElementById('cursor-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function ar(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(ar);})();
document.querySelectorAll('a,button,.track-card,.community-card').forEach(el=>{
  el.addEventListener('mouseenter',()=>ring.classList.add('big'));
  el.addEventListener('mouseleave',()=>ring.classList.remove('big'));
});

// NAV
window.addEventListener('scroll',()=>{document.getElementById('main-nav').classList.toggle('scrolled',window.scrollY>50);});
function toggleMenu(){document.getElementById('mobile-nav').classList.toggle('open');}
function closeMobileMenu(){document.getElementById('mobile-nav').classList.remove('open');}

// REVEAL
const io=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('visible');io.unobserve(x.target);}});},{threshold:.08});
document.querySelectorAll('.reveal,.reveal-l,.reveal-r').forEach(el=>io.observe(el));

// FAQ
function toggleFAQ(b){
  const item=b.parentElement,ans=b.nextElementSibling,inner=ans.querySelector('.faq-ans-inner'),open=item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el=>{el.classList.remove('open');el.querySelector('.faq-ans').style.maxHeight=null;});
  if(!open){item.classList.add('open');ans.style.maxHeight=inner.scrollHeight+'px';}
}

// DEVBOT
const bO={v:false};
const KB={
  track:'4 tracks:\n🐯 TigerGraph (Premium) — Graph tech + exclusive prizes\n⚡ Hack N Solve — FinTech/HealthTech/AI/Web3\n🌍 Sustainability — Environmental & social impact\n🔀 Duality — Interdisciplinary innovation',
  register:'Register FREE on Unstop! Search Devcation Delhi 2026. Solo or team of 2-4.',
  prize:'Prize pool ₹3,00,000+!\n🥇 1st: ₹1,50,000 + Internship + Swag\n🥈 2nd: ₹75,000 + Goodies\n🥉 3rd: ₹50,000 + Goodies\nPlus TigerGraph exclusive prizes!',
  date:'Submit by: April 4, 2026\nGrand Finale: April 12, 2026 at IIT Delhi',
  team:'1–4 members. Solo fully supported. Cross-college OK!',
  venue:'Grand Finale at IIT Delhi, India.',
  tigergraph:'Build using TigerGraph MCP. Exclusive cash prizes separate from main pool.',
  whatsapp:'https://chat.whatsapp.com/GSnoBtuBmpODdbRCf8MYxk?mode=hq1tcli — #NextStopDevcation',
  fee:'100% FREE to participate!',
  default:'Check our WhatsApp group or email gdscigdtuw@gmail.com!'
};
function bR(q){
  const l=q.toLowerCase();
  if(l.match(/track|hack|sustain|dual|tiger/))return KB.track;
  if(l.match(/register|sign|join|unstop/))return KB.register;
  if(l.match(/prize|win|money|reward/))return KB.prize;
  if(l.match(/date|when|deadline|april|finale/))return KB.date;
  if(l.match(/team|member|solo|size/))return KB.team;
  if(l.match(/venue|where|iit|location/))return KB.venue;
  if(l.match(/tigergraph|graph|mcp/))return KB.tigergraph;
  if(l.match(/whatsapp|group/))return KB.whatsapp;
  if(l.match(/fee|free|cost/))return KB.fee;
  return KB.default;
}
function aM(t,u){
  const m=document.getElementById('db-msgs'),d=document.createElement('div');
  d.className='db-msg'+(u?' u':'');
  d.innerHTML=`<div class="db-msg-av">${u?'👤':'🤖'}</div><div class="db-bub">${t.replace(/\n/g,'<br>')}</div>`;
  m.appendChild(d);m.scrollTop=m.scrollHeight;
}
function sendBot(){const i=document.getElementById('db-input'),q=i.value.trim();if(!q)return;aM(q,true);i.value='';setTimeout(()=>aM(bR(q),false),500);}
function quickAsk(q){aM(q,true);setTimeout(()=>aM(bR(q),false),500);}
function toggleBot(){
  const p=document.getElementById('devbot-panel');
  bO.v=!bO.v;p.classList.toggle('open',bO.v);
  document.getElementById('devbot-toggle').textContent=bO.v?'✕':'🤖';
}

// ACTIVE NAV
const secs=document.querySelectorAll('section[id]'),nls=document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{
  let c='';secs.forEach(s=>{if(window.scrollY>=s.offsetTop-120)c=s.id;});
  nls.forEach(a=>{a.style.color=a.getAttribute('href')==='#'+c?'var(--red3)':'';});
});
</script>
